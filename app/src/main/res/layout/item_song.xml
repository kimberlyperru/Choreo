<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:background="?attr/selectableItemBackground">

    <TextView
        android:id="@+id/tvSongEmoji"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_logo_circle"
        android:gravity="center"
        android:textSize="20sp"
        android:layout_marginStart="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/tvSongTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginStart="14dp"
        app:layout_constraintStart_toEndOf="@id/tvSongEmoji"
        app:layout_constraintTop_toTopOf="@id/tvSongEmoji"
        app:layout_constraintEnd_toStartOf="@id/tvDifficulty"/>

    <TextView
        android:id="@+id/tvComposer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="3dp"
        app:layout_constraintStart_toEndOf="@id/tvSongEmoji"
        app:layout_constraintTop_toBottomOf="@id/tvSongTitle"
        app:layout_constraintEnd_toStartOf="@id/tvDifficulty"/>

    <TextView
        android:id="@+id/tvDifficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textSize="10sp"
        android:background="@drawable/bg_logo_circle"
        android:textColor="@color/indigo_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <View
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="#2a2a4a"
        android:layout_marginTop="63dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>