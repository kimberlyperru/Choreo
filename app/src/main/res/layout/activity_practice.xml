<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/indigo_dark">

    <!-- Top bar -->
    <ImageView
        android:id="@+id/btnPracticeBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="44dp"
        android:src="@android:drawable/ic_media_previous"
        android:colorFilter="@color/white"
        android:padding="8dp"
        android:background="@drawable/bg_logo_circle"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvPracticeTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintTop_toTopOf="@id/btnPracticeBack"
        app:layout_constraintBottom_toBottomOf="@id/btnPracticeBack"
        app:layout_constraintStart_toEndOf="@id/btnPracticeBack"
        app:layout_constraintEnd_toStartOf="@id/tvPracticeInstrument"/>

    <TextView
        android:id="@+id/tvPracticeInstrument"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:textSize="12sp"
        android:textColor="@color/indigo_light"
        android:background="@drawable/bg_instrument_item"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/btnPracticeBack"
        app:layout_constraintBottom_toBottomOf="@id/btnPracticeBack"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tempo bar -->
    <LinearLayout
        android:id="@+id/tempoBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10px"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnPracticeBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TEMPO"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:layout_marginEnd="10dp"/>

        <SeekBar
            android:id="@+id/seekTempo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/indigo_mid"
            android:thumbTint="@color/indigo_light"/>

        <TextView
            android:id="@+id/tvTempoValue"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="55 BPM"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:gravity="end"
            android:layout_marginStart="10dp"/>

    </LinearLayout>

    <!-- Sheet music area -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSheet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#f8f8fc"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tempoBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvFeedback"
        app:layout_constraintHeight_percent="0.35">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvSheetPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="♩ ♪ ♫ ♬"
                android:textSize="32sp"
                android:textColor="#ccccdd"
                android:visibility="visible"/>

            <TextView
                android:id="@+id/tvCurrentNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textColor="#534AB7"
                android:background="@drawable/bg_instrument_item"
                android:text="Next: C4"/>

        </FrameLayout>

    </androidx.cardview.widget.CardView>

    <!-- Feedback banner -->
    <TextView
        android:id="@+id/tvFeedback"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:textSize="13sp"
        android:textColor="@color/white"
        android:background="@drawable/bg_instrument_item"
        android:text="🎵 Play the highlighted note to begin"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardSheet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Hint strip -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp"
        android:textSize="12sp"
        android:textColor="@color/indigo_light"
        android:background="@drawable/bg_instrument_item"
        android:text="💡 Hint: press the highlighted key below"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvFeedback"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressSong"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/indigo_mid"
        android:progressBackgroundTint="#2a2a4a"
        app:layout_constraintTop_toBottomOf="@id/tvHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- On-screen piano -->
    <TextView
        android:id="@+id/tvPianoLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TAP THE CORRECT KEY"
        android:textColor="@color/text_muted"
        android:textSize="9sp"
        android:letterSpacing="0.1"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressSong"/>

    <LinearLayout
        android:id="@+id/layoutPiano"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="6dp"
        android:background="#12122a"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvPianoLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom action buttons -->
    <LinearLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/layoutPiano"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSlow"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="🐢 Slow"
            android:textSize="12sp"
            android:backgroundTint="#2a2a4a"
            style="@style/Widget.MaterialComponents.Button"/>

        <Button
            android:id="@+id/btnMic"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:text="🎙 Mic"
            android:textSize="12sp"
            android:backgroundTint="@color/indigo_mid"
            style="@style/Widget.MaterialComponents.Button"/>

        <Button
            android:id="@+id/btnHint"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="💡 Hint"
            android:textSize="12sp"
            android:backgroundTint="#2a2a4a"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>